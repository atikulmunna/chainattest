{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chainattest.local/schemas/eval_claim.schema.json",
  "title": "EvalClaimManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attestation_id",
    "benchmark_digest",
    "eval_transcript_digest",
    "dataset_split_digest",
    "inference_config_digest",
    "randomness_seed_digest",
    "transcript_sample_count",
    "transcript_version",
    "batch_count",
    "batch_results_digest",
    "batch_correct_counts",
    "batch_incorrect_counts",
    "batch_abstain_counts",
    "correct_count",
    "incorrect_count",
    "abstain_count",
    "threshold_bps",
    "evaluator",
    "evaluator_key_id",
    "evaluator_policy_digest",
    "evaluator_policy_version"
  ],
  "properties": {
    "attestation_id": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "benchmark_digest": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "eval_transcript_digest": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "dataset_split_digest": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "inference_config_digest": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "randomness_seed_digest": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "transcript_sample_count": {
      "type": "integer",
      "minimum": 1
    },
    "transcript_version": {
      "type": "integer",
      "minimum": 1
    },
    "batch_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "batch_results_digest": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "batch_correct_counts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "batch_incorrect_counts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "batch_abstain_counts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "correct_count": {
      "type": "integer",
      "minimum": 0
    },
    "incorrect_count": {
      "type": "integer",
      "minimum": 0
    },
    "abstain_count": {
      "type": "integer",
      "minimum": 0
    },
    "threshold_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "evaluator": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "evaluator_key_id": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "evaluator_policy_digest": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "evaluator_policy_version": {
      "type": "integer",
      "minimum": 1
    }
  }
}
